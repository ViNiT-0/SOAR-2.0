## Copy to .env and fill real values
#
# cp .env.example .env
#

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Slack
# Create a Bot token (starts with xoxb-) and invite the bot to the channel.
SLACK_TOKEN=your-slack-bot-token
SLACK_CHANNEL=#soc-alerts

# VirusTotal
VT_API_KEY=your-virustotal-api-key

# n8n (optional)
N8N_WEBHOOK=http://localhost:5678/webhook/soc-alert

